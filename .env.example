# Do not use the VITE_ prefix: every value in this file is server-only.
TELEGRAM_BOT_TOKEN=replace-with-your-token

# Before the first /setup this can be the owner's private chat ID. The setup
# command replaces it with the private forum supergroup ID.
TELEGRAM_CHAT_ID=replace-with-private-chat-or-supergroup-id
TELEGRAM_OWNER_USER_ID=replace-with-owner-user-id
TELEGRAM_ADMIN_USER_IDS=replace-with-owner-user-id

# The setup command creates and fills these four topic IDs.
TELEGRAM_NEW_TOPIC_ID=replace-with-new-requests-topic-id
TELEGRAM_CONFIRMED_TOPIC_ID=replace-with-confirmed-topic-id
TELEGRAM_ARCHIVE_TOPIC_ID=replace-with-archive-topic-id
TELEGRAM_TRIP_TOPIC_ID=replace-with-trip-requests-topic-id

# Generate two different secrets of at least 32 URL-safe characters.
TELEGRAM_WEBHOOK_SECRET=replace-with-random-a-z-A-Z-0-9-_-secret
BOOKING_RATE_LIMIT_SECRET=replace-with-a-different-long-random-secret

# Use the pooled booking_app connection string from Neon in Netlify Functions.
DATABASE_URL=postgresql://booking_app:password@ep-example-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Used only by the one-time Telegram setup after the Netlify production deploy.
PUBLIC_SITE_URL=https://your-netlify-site.netlify.app
